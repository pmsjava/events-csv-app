{
    "name": "events/csv-app",
    "description": "Simple PHP app that reads orders from CSV and displays event list with UTM ranking.",
    "license": "proprietary",
    "type": "project",
    "require": {
        "php": "^8.5"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.90",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "cs:check": "vendor/bin/php-cs-fixer fix --diff --dry-run -vvv",
        "cs:fix": "vendor/bin/php-cs-fixer fix -vvv",
        "verify": [
            "@composer validate --strict",
            "@test",
            "@cs:check"
        ]
    }
}
